# 正式接口根路径；生产环境必须使用 HTTPS，并保留末尾 /。
NEXT_PUBLIC_JUHAO_API_BASE_URL=https://api.juhao.com/v1/

# 私有预览默认关闭公开索引。正式域名未签核前即使做公开模式模拟，也不能通过发布门禁。
SITE_CANONICAL_ORIGIN=https://juhao.com
PUBLIC_INDEXING_ENABLED=false
CANONICAL_HOST_APPROVED=false

# 可选的内部线索通知 Webhook；只在服务端配置，不要使用 NEXT_PUBLIC_ 前缀。
JUHAO_LEAD_WEBHOOK_URL=
JUHAO_LEAD_WEBHOOK_SECRET=

# 保持 false 时供所有者私有预览测试；公开入口启用前须配置 Turnstile、Webhook、维护任务和两级限流。
PUBLIC_INTAKE_READY=false
# Cloudflare Turnstile 公钥会进入浏览器包；与下方服务端私钥配套使用。
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# 仅填写已在 Turnstile 后台批准的主机名，多个值用逗号分隔，不含协议或路径。
TURNSTILE_ALLOWED_HOSTNAMES=
# Cloudflare 边缘/WAF 的咨询接口前置限流经负责人验收后才可设为 true。
CONTACT_EDGE_RATE_LIMIT_VERIFIED=false
JUHAO_LEAD_MAINTENANCE_SECRET=
# 用于 HMAC-SHA-256 限流摘要，至少填写 32 个随机字符；不得复用其他业务密钥。
JUHAO_LEAD_RATE_LIMIT_SECRET=

# 人工产品审核台在开发模式默认可用；生产模式即使是本机预览，也必须显式开启。
# Worker 仍会拒绝所有非 localhost / 127.0.0.1 的 /catalog-lab 请求。
CATALOG_REVIEW_WORKBENCH_ENABLED=false
