{
  "name": "site-creator-vinext-starter",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "python3 scripts/build_knowledge_library.py --check && python3 scripts/source_freeze.py --check && python3 scripts/build_company_news_runtime.py --check && python3 scripts/build_product_catalog.py --catalog-v2 --check && WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build && node scripts/prune_dist_media.mjs",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "npm run build && node --import ./tests/register-cloudflare-loader.mjs --test tests/*.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next --ignore-pattern 'RECON/**'",
    "typecheck": "tsc --noEmit --incremental false",
    "check:bundle": "node --import ./tests/register-cloudflare-loader.mjs scripts/check_bundle_budget.mjs",
    "check:dist-leaks": "node scripts/check_dist_leaks.mjs",
    "check:seo-public": "node --import ./tests/register-cloudflare-loader.mjs scripts/check_public_seo_simulation.mjs",
    "check:a11y": "node scripts/check_accessibility.mjs",
    "check:visual-routes": "node scripts/check_visual_routes.mjs",
    "check:sources": "python3 scripts/source_freeze.py --check-external",
    "check:release": "node scripts/check_launch_health.mjs --release-gate",
    "check:dist": "npm run check:bundle; bundle=$?; npm run check:dist-leaks; leaks=$?; test $bundle -eq 0 -a $leaks -eq 0",
    "db:generate": "drizzle-kit generate",
    "content:company-news": "python3 scripts/build_company_news_runtime.py",
    "content:knowledge": "python3 scripts/build_knowledge_library.py --write",
    "content:catalog-v2": "python3 scripts/build_product_catalog.py --catalog-v2",
    "check:catalog-v2": "python3 scripts/build_product_catalog.py --catalog-v2 --check"
  },
  "dependencies": {
    "@gsap/react": "2.1.2",
    "drizzle-orm": "0.45.2",
    "gsap": "3.15.0",
    "next": "16.2.11",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@cloudflare/vite-plugin": "1.46.0",
    "@cloudflare/workers-types": "5.20260721.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitejs/plugin-rsc": "0.5.27",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.11",
    "playwright": "1.61.1",
    "react-server-dom-webpack": "19.2.6",
    "sharp": "0.35.3",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.1.4",
    "wrangler": "4.113.0"
  },
  "overrides": {
    "sharp": "$sharp",
    "next": {
      "postcss": "8.5.10"
    }
  },
  "type": "module"
}
