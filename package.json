{
  "name": "site-creator-vinext-starter",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "python3 scripts/source_freeze.py --check && python3 scripts/build_company_news_runtime.py --check && WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build && node scripts/prune_dist_media.mjs",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "npm run build && node --import ./tests/register-cloudflare-loader.mjs --test tests/*.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next --ignore-pattern 'RECON/**'",
    "check:bundle": "node --import ./tests/register-cloudflare-loader.mjs scripts/check_bundle_budget.mjs",
    "check:dist-leaks": "node scripts/check_dist_leaks.mjs",
    "check:seo-public": "node --import ./tests/register-cloudflare-loader.mjs scripts/check_public_seo_simulation.mjs",
    "check:dist": "npm run check:bundle; bundle=$?; npm run check:dist-leaks; leaks=$?; test $bundle -eq 0 -a $leaks -eq 0",
    "db:generate": "drizzle-kit generate",
    "content:company-news": "python3 scripts/build_company_news_runtime.py"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@cloudflare/workers-types": "^4.20260702.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "sharp": "0.34.5",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
